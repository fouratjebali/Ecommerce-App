{
  "name": "greencraft-marketplace",
  "version": "0.1.0",
  "private": true,
  "description": "GreenCraft Marketplace monorepo for the Angular storefront and NestJS commerce platform.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run start --workspace greencraft-web",
    "dev:api": "npm run start:dev --workspace greencraft-api",
    "build:web": "npm run build --workspace greencraft-web",
    "build:api": "npm run build --workspace greencraft-api",
    "test:web": "npm run test --workspace greencraft-web",
    "test:api": "npm run test --workspace greencraft-api",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f",
    "format:check": "npm exec --workspace greencraft-web prettier --check \"src/**/*.{ts,scss,html}\""
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fouratjebali/Ecommerce-App.git"
  },
  "bugs": {
    "url": "https://github.com/fouratjebali/Ecommerce-App/issues"
  },
  "homepage": "https://github.com/fouratjebali/Ecommerce-App#readme",
  "keywords": [
    "angular",
    "nestjs",
    "marketplace",
    "sustainability",
    "handmade"
  ],
  "license": "UNLICENSED"
}
