generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ARTISAN
  BUYER
}

enum VendorStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AttributeKind {
  TEXT
  NUMBER
  BOOLEAN
  SELECT
  MULTI_SELECT
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  FULFILLING
  COMPLETED
  CANCELLED
}

enum OrderItemStatus {
  CONFIRMED
  FULFILLING
  SHIPPED
  CANCELLED
}

enum InventoryReservationStatus {
  ACTIVE
  CONSUMED
  RELEASED
  EXPIRED
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  fullName       String
  passwordHash   String
  role           UserRole        @default(BUYER)
  avatarUrl      String?
  artisanProfile ArtisanProfile?
  orders         Order[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model ArtisanProfile {
  id                 String       @id @default(uuid())
  userId             String       @unique
  slug               String       @unique
  studioName         String
  headline           String
  bio                String       @db.Text
  location           String
  impactStatement    String       @db.Text
  verificationStatus VendorStatus @default(PENDING)
  verified           Boolean      @default(false)
  responseRate       Int          @default(92)
  averageRating      Float        @default(4.8)
  totalSales         Int          @default(0)
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  products           Product[]
  orderItems         OrderItem[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model Category {
  id          String    @id @default(uuid())
  slug        String    @unique
  name        String
  description String
  products    Product[]
}

model MaterialTag {
  id                  String            @id @default(uuid())
  slug                String            @unique
  name                String
  origin              String
  description         String
  sustainabilityScore Int
  productMaterials    ProductMaterial[]
}

model EcoRating {
  id          String    @id @default(uuid())
  code        String    @unique
  label       String
  score       Int
  description String
  products    Product[]
}

model Product {
  id               String                @id @default(uuid())
  artisanId        String
  categoryId       String
  ecoRatingId      String
  slug             String                @unique
  name             String
  shortDescription String
  description      String                @db.Text
  story            String                @db.Text
  currency         String                @default("USD")
  priceInCents     Int
  inventoryCount   Int
  impactScore      Int
  co2SavedKg       Float
  leadTimeDays     Int                   @default(5)
  status           ProductStatus         @default(DRAFT)
  isFeatured       Boolean               @default(false)
  artisan          ArtisanProfile        @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  category         Category              @relation(fields: [categoryId], references: [id])
  ecoRating        EcoRating             @relation(fields: [ecoRatingId], references: [id])
  images           ProductImage[]
  materials        ProductMaterial[]
  attributes       ProductAttributeValue[]
  orderItems       OrderItem[]
  reservations     InventoryReservation[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([artisanId, status])
  @@index([categoryId, status])
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  url       String
  alt       String
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductMaterial {
  productId     String
  materialTagId String
  percentage    Int?
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  materialTag   MaterialTag @relation(fields: [materialTagId], references: [id], onDelete: Cascade)

  @@id([productId, materialTagId])
}

model ProductAttributeDefinition {
  id           String                   @id @default(uuid())
  code         String                   @unique
  label        String
  kind         AttributeKind
  filterGroup  String
  unit         String?
  facetEnabled Boolean                  @default(true)
  sortOrder    Int                      @default(0)
  options      ProductAttributeOption[]
  values       ProductAttributeValue[]
}

model ProductAttributeOption {
  id           String                     @id @default(uuid())
  definitionId String
  value        String
  label        String
  sortOrder    Int                        @default(0)
  definition   ProductAttributeDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  values       ProductAttributeValue[]

  @@unique([definitionId, value])
}

model ProductAttributeValue {
  id           String                     @id @default(uuid())
  productId    String
  definitionId String
  optionId     String?
  valueText    String?
  valueNumber  Float?
  valueBoolean Boolean?
  product      Product                    @relation(fields: [productId], references: [id], onDelete: Cascade)
  definition   ProductAttributeDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  option       ProductAttributeOption?    @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@index([productId, definitionId])
}

model Coupon {
  id                    String     @id @default(uuid())
  code                  String     @unique
  label                 String
  description           String
  type                  CouponType
  percentOff            Int?
  amountOffInCents      Int?
  minimumSubtotalInCents Int       @default(0)
  maxDiscountInCents    Int?
  active                Boolean    @default(true)
  startsAt              DateTime?
  endsAt                DateTime?
  usageLimit            Int?
  timesRedeemed         Int        @default(0)
  orders                Order[]
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}

model Order {
  id                    String                @id @default(uuid())
  orderNumber           String                @unique
  buyerId               String
  couponId              String?
  cartSessionId         String
  status                OrderStatus           @default(CONFIRMED)
  currency              String                @default("USD")
  subtotalInCents       Int
  couponDiscountInCents Int                   @default(0)
  bundleDiscountInCents Int                   @default(0)
  totalInCents          Int
  shippingName          String
  shippingEmail         String
  shippingAddressLine1  String
  shippingAddressLine2  String?
  shippingCity          String
  shippingPostalCode    String
  shippingCountry       String
  notes                 String?
  placedAt              DateTime              @default(now())
  buyer                 User                  @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  coupon                Coupon?               @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items                 OrderItem[]
  reservations          InventoryReservation[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([buyerId, status])
}

model OrderItem {
  id                 String          @id @default(uuid())
  orderId            String
  productId          String
  artisanId          String
  status             OrderItemStatus @default(CONFIRMED)
  productName        String
  artisanStudioName  String
  unitPriceInCents   Int
  quantity           Int
  lineTotalInCents   Int
  impactScore        Int
  co2SavedKg         Float
  currency           String          @default("USD")
  order              Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product            Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  artisan            ArtisanProfile  @relation(fields: [artisanId], references: [id], onDelete: Restrict)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([orderId, status])
  @@index([artisanId, status])
}

model InventoryReservation {
  id         String                     @id @default(uuid())
  sessionId  String
  productId  String
  orderId    String?
  quantity   Int
  status     InventoryReservationStatus @default(ACTIVE)
  expiresAt  DateTime
  product    Product                    @relation(fields: [productId], references: [id], onDelete: Cascade)
  order      Order?                     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt

  @@index([productId, status, expiresAt])
  @@index([sessionId, status, expiresAt])
}
